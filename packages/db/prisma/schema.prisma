generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Bot template — a reusable recipe (e.g., "ESPN Scoreboard Scraper")
model BotTemplate {
  id            String   @id @default(cuid())
  name          String
  description   String?
  poolType      String // browser | scraper | rpa_desktop | discord | telegram | trading | monitor | mcp_host | ci_agent | task_runner | ai_agent
  configSchema  Json // JSON Schema for params
  defaultConfig Json
  // Phase 5b: optional dispatch-time placement. Shape: { region?: string; zone?: string }.
  // Null = no preference; bots based on this template route to the
  // `hive:pool:<pool>:any:any` stream by default.
  affinity      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  bots          Bot[]

  @@index([poolType])
}

// Bot — an instantiated template with concrete params
model Bot {
  id               String      @id @default(cuid())
  templateId       String
  template         BotTemplate @relation(fields: [templateId], references: [id])
  name             String
  config           Json
  // Phase 5b: overrides template.affinity when set. Same shape: { region?, zone? }.
  // Null = inherit from template.
  affinityOverride Json?
  enabled          Boolean     @default(true)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  jobs             Job[]
  schedules        Schedule[]

  @@index([templateId])
}

// Job — a single execution of a bot
model Job {
  id          String    @id @default(cuid())
  botId       String
  bot         Bot       @relation(fields: [botId], references: [id], onDelete: Cascade)
  status      String // queued | running | succeeded | failed | cancelled
  priority    Int       @default(0)
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  payload     Json
  result      Json?
  error       String?
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime  @default(now())
  logs        JobLog[]

  @@index([status])
  @@index([botId])
  @@index([createdAt])
}

model JobLog {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  level     String // debug | info | warn | error
  message   String
  meta      Json?
  timestamp DateTime @default(now())

  @@index([jobId, timestamp])
}

model Schedule {
  id        String    @id @default(cuid())
  botId     String
  bot       Bot       @relation(fields: [botId], references: [id], onDelete: Cascade)
  cron      String // cron expression
  enabled   Boolean   @default(true)
  lastRunAt DateTime?
  nextRunAt DateTime?
  createdAt DateTime  @default(now())

  @@index([nextRunAt, enabled])
}

model Worker {
  id         String   @id @default(cuid())
  poolType   String
  hostname   String
  // Phase 5b: self-declared location for affinity-based routing. Single-host
  // setups leave these at the defaults and everything keeps working.
  region     String   @default("local")
  zone       String   @default("default")
  status     String // online | offline | draining
  capacity   Int      @default(1)
  activeJobs Int      @default(0)
  lastSeenAt DateTime @default(now())
  metadata   Json?

  @@index([poolType, status])
  @@index([poolType, region, zone])
}

model AiUsage {
  id           String   @id @default(cuid())
  jobId        String?
  provider     String // claude | gpt | perplexity
  model        String
  inputTokens  Int
  outputTokens Int
  costCents    Int
  createdAt    DateTime @default(now())

  @@index([provider, createdAt])
}

// ============ Trading (Phase 3b) ============

model PaperWallet {
  id        String   @id @default(cuid())
  exchange  String
  currency  String
  balance   Decimal  @default(0) @db.Decimal(18, 8)
  botId     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([exchange, currency])
  @@index([botId])
}

model PaperTrade {
  id            String   @id @default(cuid())
  jobId         String
  exchange      String
  symbol        String
  side          String // buy | sell
  type          String // market | limit
  amount        Decimal  @db.Decimal(18, 8)
  price         Decimal? @db.Decimal(18, 8)
  status        String // filled | cancelled | failed
  executedPrice Decimal? @db.Decimal(18, 8)
  createdAt     DateTime @default(now())

  @@index([jobId])
  @@index([symbol, createdAt])
}

model TradeAudit {
  id        String   @id @default(cuid())
  jobId     String
  botId     String
  mode      String // paper | live
  action    String
  payload   Json
  result    Json
  createdAt DateTime @default(now())

  @@index([botId, createdAt])
  @@index([mode, createdAt])
  @@index([jobId])
}

// ============ Auth (Phase 3c) ============

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  passwordHash String
  displayName  String
  role         String       @default("user") // admin | user
  createdAt    DateTime     @default(now())
  lastLoginAt  DateTime?
  sessions     Session[]
  resetTokens  ResetToken[]
  auditEntries AuditLog[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  ipAddress String?
  userAgent String?

  @@index([userId])
  @@index([expiresAt])
}

// ============ Password reset (Phase 6b) ============

// Single-use password reset token. We store only the SHA-256 hash of the raw
// token (same pattern as Session.tokenHash) so a DB leak can't be used to reset
// passwords. `usedAt` is set when consumed so a token can't be replayed.
model ResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// ============ KMS keys (Phase 5a) ============

// Tracks every KEK that has wrapped DEKs in this database. Used by
// `pnpm --filter @hive/api kms:rotate` to find which envelopes to re-wrap.
model KmsKey {
  id        String    @id @default(cuid())
  keyId     String    @unique // provider-specific identifier (e.g., AWS KMS ARN, 'static:v1')
  provider  String // 'static' | 'aws'
  status    String // 'active' | 'retiring' | 'revoked'
  createdAt DateTime  @default(now())
  retiredAt DateTime?

  @@index([status])
}

// ============ Artifacts (Phase 4b) ============

model Artifact {
  id              String   @id @default(cuid())
  jobId           String
  filename        String
  contentType     String
  sizeBytes       Int
  // Provider-internal key (e.g., 'jobId/file.png'). Renamed from `path` in
  // Phase 5a so the abstraction works for S3 as well as local FS.
  storageKey      String
  storageProvider String   @default("local") // 'local' | 's3'
  createdAt       DateTime @default(now())

  @@index([jobId, createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  targetType String?
  targetId   String?
  payload    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
}
