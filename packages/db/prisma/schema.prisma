generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Bot template — a reusable recipe (e.g., "ESPN Scoreboard Scraper")
model BotTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  poolType    String   // browser | scraper | rpa_desktop | discord | telegram | trading | monitor | mcp_host | ci_agent | task_runner | ai_agent
  configSchema Json    // JSON Schema for params
  defaultConfig Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  bots        Bot[]

  @@index([poolType])
}

// Bot — an instantiated template with concrete params
model Bot {
  id          String   @id @default(cuid())
  templateId  String
  template    BotTemplate @relation(fields: [templateId], references: [id])
  name        String
  config      Json
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  jobs        Job[]
  schedules   Schedule[]

  @@index([templateId])
}

// Job — a single execution of a bot
model Job {
  id          String   @id @default(cuid())
  botId       String
  bot         Bot      @relation(fields: [botId], references: [id])
  status      String   // queued | running | succeeded | failed | cancelled
  priority    Int      @default(0)
  attempts    Int      @default(0)
  maxAttempts Int      @default(3)
  payload     Json
  result      Json?
  error       String?
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime @default(now())
  logs        JobLog[]

  @@index([status])
  @@index([botId])
  @@index([createdAt])
}

model JobLog {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  level     String   // debug | info | warn | error
  message   String
  meta      Json?
  timestamp DateTime @default(now())

  @@index([jobId, timestamp])
}

model Schedule {
  id        String   @id @default(cuid())
  botId     String
  bot       Bot      @relation(fields: [botId], references: [id])
  cron      String   // cron expression
  enabled   Boolean  @default(true)
  lastRunAt DateTime?
  nextRunAt DateTime?
  createdAt DateTime @default(now())

  @@index([nextRunAt, enabled])
}

model Worker {
  id           String   @id @default(cuid())
  poolType     String
  hostname     String
  status       String   // online | offline | draining
  capacity     Int      @default(1)
  activeJobs   Int      @default(0)
  lastSeenAt   DateTime @default(now())
  metadata     Json?

  @@index([poolType, status])
}

model AiUsage {
  id        String   @id @default(cuid())
  jobId     String?
  provider  String   // claude | gpt | perplexity
  model     String
  inputTokens  Int
  outputTokens Int
  costCents Int
  createdAt DateTime @default(now())

  @@index([provider, createdAt])
}
