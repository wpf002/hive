# ============ Core Infrastructure ============
DATABASE_URL=postgresql://hive:hive@localhost:5432/hive
REDIS_URL=redis://localhost:6379

# ============ Control Plane ============
API_PORT=4000
UI_PORT=3001
DISPATCHER_PORT=4100
NODE_ENV=development
LOG_LEVEL=info
API_BASE_URL=http://localhost:4000

# ============ Auth ============
# Generate strong tokens with: openssl rand -hex 32
# API_AUTH_TOKEN  — UI / users on /api/* routes (except /healthz)
# WORKER_AUTH_TOKEN — worker heartbeats
API_AUTH_TOKEN=
WORKER_AUTH_TOKEN=
JWT_SECRET=change-me-in-production
SESSION_SECRET=change-me-in-production

# ============ UI (Next.js) ============
# NEXT_PUBLIC_* values are inlined into the browser bundle.
# This is fine for local dev only — never use a production token here.
NEXT_PUBLIC_API_BASE=http://localhost:4000
NEXT_PUBLIC_API_TOKEN=

# ============ AI Providers ============
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
PERPLEXITY_API_KEY=

# ============ Discord ============
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=

# ============ Telegram ============
TELEGRAM_BOT_TOKEN=

# ============ Trading / Sportsbook ============
ESPN_API_BASE=https://site.api.espn.com/apis/site/v2/sports
CROSSBAR_API_URL=http://localhost:3001

# ============ Cloud (Phase 2) ============
