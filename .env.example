# ============ Core Infrastructure ============
DATABASE_URL=postgresql://hive:hive@localhost:5432/hive
REDIS_URL=redis://localhost:6379

# ============ Control Plane ============
API_PORT=4000
UI_PORT=3001
DISPATCHER_PORT=4100
SCHEDULER_PORT=4102
SESSION_SWEEPER_PORT=4103
NODE_ENV=development
LOG_LEVEL=info
API_BASE_URL=http://localhost:4000

# ============ Auth ============
# Generate strong tokens with: openssl rand -hex 32
# API_AUTH_TOKEN  — UI / users on /api/* routes (except /healthz)
# WORKER_AUTH_TOKEN — worker heartbeats
API_AUTH_TOKEN=
WORKER_AUTH_TOKEN=
JWT_SECRET=change-me-in-production
SESSION_SECRET=change-me-in-production

# ============ Secrets-at-rest (Phase 4a + 5a envelope) ============
# Master key for field-level AEAD encryption of bot secrets. Also acts as the
# default KEK for the static KMS provider (Phase 5a envelope encryption).
# Generate with: `openssl rand -hex 32`. The API refuses to start without this.
HIVE_SECRETS_KEY=

# ============ KMS (Phase 5a) ============
# Pluggable Key Encryption Key provider. 'static' uses HIVE_SECRETS_KEY as the
# KEK (default; fine for dev). 'aws' calls AWS KMS — requires HIVE_KMS_KEY_ID
# and IAM permissions for kms:Encrypt / kms:Decrypt on that key.
HIVE_KMS_PROVIDER=static
# Identifier reported for the static-provider's current KEK. Bump (e.g.
# 'static:v2') when you rotate so KmsKey rows stay distinguishable.
HIVE_KMS_STATIC_KEY_ID=static:v1
# Comma-separated 'keyId=hexKey' pairs that the static provider can still
# decrypt with. Populate during a rotation window so the kms:rotate sweep
# can unwrap DEKs that were wrapped under the previous KEK.
# HIVE_KMS_STATIC_RETIRED_KEYS=static:v0=00112233...
# For HIVE_KMS_PROVIDER=aws only:
# HIVE_KMS_KEY_ID=arn:aws:kms:us-east-1:123456789012:key/abc-...

# ============ Artifacts (Phase 4b + 5a storage) ============
# Base directory used by the LOCAL storage provider. Created on first write.
# Ignored when HIVE_STORAGE_PROVIDER=s3.
HIVE_ARTIFACT_DIR=./data/artifacts
# Pluggable artifact backend. 'local' = filesystem, 's3' = S3-compatible.
HIVE_STORAGE_PROVIDER=local
# For HIVE_STORAGE_PROVIDER=s3 only: target bucket (required), optional custom
# endpoint (blank = AWS S3), and region.
# HIVE_ARTIFACT_S3_BUCKET=hive-artifacts
# HIVE_ARTIFACT_S3_ENDPOINT=http://localhost:9000   # MinIO for local dev
# HIVE_ARTIFACT_S3_REGION=us-east-1

# ============ UI (Next.js) ============
# NEXT_PUBLIC_* values are inlined into the browser bundle.
# This is fine for local dev only — never use a production token here.
NEXT_PUBLIC_API_BASE=http://localhost:4000
#
# Migration note (Phase 3c → 4): NEXT_PUBLIC_API_TOKEN was removed. The UI now
# authenticates via session cookies set by POST /api/auth/login. The legacy
# var is no longer read by lib/api.ts in Phase 4+. If you still see it in
# your local .env from an older copy, you can delete it after your first
# successful login.

# ============ Auth — Phase 3c ============
# Required on first run when no admin user exists — seed creates one and aborts
# if these are blank. Use a real-looking email; zod's .email() rejects bare
# locals like "admin@local".
ADMIN_EMAIL=admin@hive.dev
ADMIN_PASSWORD=change-me-on-first-login
# When 'true', POST /api/auth/register is open to anyone. Default: false
# (admin creates user accounts manually via /admin/users or the API).
SIGNUPS_ENABLED=false
# When 'true', session cookies are marked Secure (HTTPS only). Leave 'false'
# for plain-HTTP localhost; flip 'true' in any non-dev deploy.
SECURE_COOKIES=false

# ============ Transactional email (Phase 6b) ============
# Provider for password-reset + audit-alert email. 'log' (default) never sends
# real mail — it logs the message (and the reset link) to stdout, which is all
# you need for local dev. 'resend' sends via the Resend REST API.
HIVE_EMAIL_PROVIDER=log
# Required only when HIVE_EMAIL_PROVIDER=resend. Get the key from the Resend
# dashboard; the from-address must be on a verified Resend sending domain.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
# Public origin of the UI — used to build the password-reset link in emails
# AND as the primary allowed CORS origin. Defaults to the local dev UI; set to
# https://hive.<yourdomain> in production.
HIVE_PUBLIC_APP_URL=http://localhost:3001
# Optional: extra browser origins allowed to make credentialed CORS requests,
# comma-separated. HIVE_PUBLIC_APP_URL is always allowed; localhost is
# auto-allowed in development. Leave blank unless the UI is served from another
# origin (e.g. a separate admin domain).
HIVE_CORS_ORIGINS=
# Monitor worker SSRF guard. By default the HTTP-endpoint monitor refuses to
# fetch URLs that resolve to private/loopback/link-local addresses (blocks the
# 169.254.169.254 cloud-metadata endpoint, internal services, etc). Set to
# true ONLY if you intentionally monitor internal targets.
HIVE_MONITOR_ALLOW_INTERNAL=false
# Optional: when set, critical audit events (failed-login spikes, admin role
# changes, trading live-mode enable, password resets) email this address. The
# session-sweeper service runs the polling job; needs REDIS_URL for dedupe.
HIVE_AUDIT_ALERT_EMAIL=

# ============ AI Providers ============
# Required for ai_agent workers. Each provider is independent — leave blank
# to disable that provider (multi-provider mode reports per-provider errors;
# single-call mode fails the job).
# Defaults: claude=claude-sonnet-4-5, gpt=gpt-4o, perplexity=sonar-pro
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
PERPLEXITY_API_KEY=



# ============ Trading / Sportsbook ============
ESPN_API_BASE=https://site.api.espn.com/apis/site/v2/sports
CROSSBAR_API_URL=http://localhost:3001
# the-odds-api.com — free tier 500 req/mo. Used by Sportsbook Line Scraper.
# Public DK/FD endpoints reject non-residential IPs; this aggregator returns
# the same per-book data without bot-management friction.
ODDS_API_KEY=

# Hard gate for the trading pool. Default 'false' → all 'live'-mode trading
# bots refuse to run with a clear error. Set to 'true' on the trading worker
# (and restart it + the API) to enable real exchange calls. The UI also shows
# a permanent red banner site-wide whenever this is true.
TRADING_LIVE_ENABLED=false

# ============ Worker fleet location (Phase 5b) ============
# Workers self-declare their region + zone so the dispatcher can route jobs
# with affinity preferences. Defaults keep single-host deployments working
# unchanged — set these on remote worker hosts to opt into multi-host fleets.
HIVE_WORKER_REGION=local
HIVE_WORKER_ZONE=default
# How long the dispatcher waits for a worker to claim a queued job before
# marking it 'unroutable'. 60s tolerates short scale-from-zero windows;
# 300s is reasonable if your fleet boots slowly.
# HIVE_UNROUTABLE_TIMEOUT_S=60
# Optional /healthz HTTP port for workers (Phase 6c). 0/unset = disabled
# (workers are stream consumers, not HTTP services). The /status page derives
# worker health from heartbeats, so this is only needed for direct HTTP probes.
HIVE_WORKER_HEALTHZ_PORT=0

# ============ Monitoring / status (Phase 6c) ============
# Surfaced in /healthz and on the /status page. In production, set these at
# deploy time (e.g. from the git SHA and deploy timestamp).
# HIVE_VERSION=0.1.0
# HIVE_GIT_SHA=
# HIVE_DEPLOYED_AT=
# Browser-bundle copies for the login footer + status page (NEXT_PUBLIC_*).
NEXT_PUBLIC_HIVE_VERSION=0.1.0
NEXT_PUBLIC_HIVE_REGION=local
# Optional: let the API probe the other control-plane services' /healthz so the
# /status page can show their real status (otherwise they render 'unknown').
# HIVE_DISPATCHER_URL=https://hive-dispatcher.fly.dev
# HIVE_SCHEDULER_URL=https://hive-scheduler.fly.dev
# HIVE_SWEEPER_URL=https://hive-session-sweeper.fly.dev

# ============ Cloud (Phase 5c) ============
# Human-readable environment tag rendered as a colored pill in the UI top bar.
# Helps prevent "did I just run that in production?" mistakes. Leave blank in
# dev; set to 'staging' / 'production' / etc. in deployed environments.
# HIVE_ENV_LABEL=staging
#
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# FLY_API_TOKEN=
# RAILWAY_TOKEN=
