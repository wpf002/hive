# ============ Core Infrastructure ============
DATABASE_URL=postgresql://hive:hive@localhost:5432/hive
REDIS_URL=redis://localhost:6379

# ============ Control Plane ============
API_PORT=4000
UI_PORT=3000
DISPATCHER_PORT=4100
NODE_ENV=development
LOG_LEVEL=info

# ============ Auth ============
JWT_SECRET=change-me-in-production
SESSION_SECRET=change-me-in-production

# ============ AI Providers ============
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
PERPLEXITY_API_KEY=

# ============ Worker Tokens (per-pool auth) ============
WORKER_AUTH_TOKEN=change-me

# ============ Discord ============
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=

# ============ Telegram ============
TELEGRAM_BOT_TOKEN=

# ============ Trading / Sportsbook ============
ESPN_API_BASE=https://site.api.espn.com/apis/site/v2/sports
CROSSBAR_API_URL=http://localhost:3001

