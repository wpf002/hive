# ============ Core Infrastructure ============
DATABASE_URL=postgresql://hive:hive@localhost:5432/hive
REDIS_URL=redis://localhost:6379

# ============ Control Plane ============
API_PORT=4000
UI_PORT=3001
DISPATCHER_PORT=4100
SCHEDULER_PORT=4102
SESSION_SWEEPER_PORT=4103
NODE_ENV=development
LOG_LEVEL=info
API_BASE_URL=http://localhost:4000

# ============ Auth ============
# Generate strong tokens with: openssl rand -hex 32
# API_AUTH_TOKEN  — UI / users on /api/* routes (except /healthz)
# WORKER_AUTH_TOKEN — worker heartbeats
API_AUTH_TOKEN=
WORKER_AUTH_TOKEN=
JWT_SECRET=change-me-in-production
SESSION_SECRET=change-me-in-production

# ============ Secrets-at-rest (Phase 4a) ============
# Master key for field-level AEAD encryption of bot secrets (botToken, apiKey,
# apiSecret, …). Generate with: `openssl rand -hex 32`
# WARNING: rotating this key invalidates every encrypted value already in
# Postgres. There is no auto re-encrypt path yet (Phase 5). If you rotate,
# every bot with x-secret fields will need its config rewritten in the UI.
# `make rotate-secrets-key` prints a roadmap TODO.
# The API refuses to start without this set.
HIVE_SECRETS_KEY=

# ============ Artifacts (Phase 4b) ============
# Base directory on the API host for files uploaded by workers (screenshots,
# OCR captures, build logs, …). Created on first write. Phase 5 will swap
# for an S3 backend.
HIVE_ARTIFACT_DIR=./data/artifacts

# ============ UI (Next.js) ============
# NEXT_PUBLIC_* values are inlined into the browser bundle.
# This is fine for local dev only — never use a production token here.
NEXT_PUBLIC_API_BASE=http://localhost:4000
#
# Migration note (Phase 3c → 4): NEXT_PUBLIC_API_TOKEN was removed. The UI now
# authenticates via session cookies set by POST /api/auth/login. The legacy
# var is no longer read by lib/api.ts in Phase 4+. If you still see it in
# your local .env from an older copy, you can delete it after your first
# successful login.

# ============ Auth — Phase 3c ============
# Required on first run when no admin user exists — seed creates one and aborts
# if these are blank. Use a real-looking email; zod's .email() rejects bare
# locals like "admin@local".
ADMIN_EMAIL=admin@hive.dev
ADMIN_PASSWORD=change-me-on-first-login
# When 'true', POST /api/auth/register is open to anyone. Default: false
# (admin creates user accounts manually via /admin/users or the API).
SIGNUPS_ENABLED=false
# When 'true', session cookies are marked Secure (HTTPS only). Leave 'false'
# for plain-HTTP localhost; flip 'true' in any non-dev deploy.
SECURE_COOKIES=false

# ============ AI Providers ============
# Required for ai_agent workers. Each provider is independent — leave blank
# to disable that provider (multi-provider mode reports per-provider errors;
# single-call mode fails the job).
# Defaults: claude=claude-sonnet-4-5, gpt=gpt-4o, perplexity=sonar-pro
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
PERPLEXITY_API_KEY=

# ============ Discord ============
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=

# ============ Telegram ============
TELEGRAM_BOT_TOKEN=

# ============ Trading / Sportsbook ============
ESPN_API_BASE=https://site.api.espn.com/apis/site/v2/sports
CROSSBAR_API_URL=http://localhost:3001
# the-odds-api.com — free tier 500 req/mo. Used by Sportsbook Line Scraper.
# Public DK/FD endpoints reject non-residential IPs; this aggregator returns
# the same per-book data without bot-management friction.
ODDS_API_KEY=

# Hard gate for the trading pool. Default 'false' → all 'live'-mode trading
# bots refuse to run with a clear error. Set to 'true' on the trading worker
# (and restart it + the API) to enable real exchange calls. The UI also shows
# a permanent red banner site-wide whenever this is true.
TRADING_LIVE_ENABLED=false

# ============ Cloud (Phase 5) ============
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# FLY_API_TOKEN=
# RAILWAY_TOKEN=
