# ============ Core Infrastructure ============
DATABASE_URL=postgresql://hive:hive@localhost:5432/hive
REDIS_URL=redis://localhost:6379

# ============ Control Plane ============
API_PORT=4000
UI_PORT=3001
DISPATCHER_PORT=4100
SCHEDULER_PORT=4102
NODE_ENV=development
LOG_LEVEL=info
API_BASE_URL=http://localhost:4000

# ============ Auth ============
# Generate strong tokens with: openssl rand -hex 32
# API_AUTH_TOKEN  — UI / users on /api/* routes (except /healthz)
# WORKER_AUTH_TOKEN — worker heartbeats
API_AUTH_TOKEN=
WORKER_AUTH_TOKEN=
JWT_SECRET=change-me-in-production
SESSION_SECRET=change-me-in-production

# ============ UI (Next.js) ============
# NEXT_PUBLIC_* values are inlined into the browser bundle.
# This is fine for local dev only — never use a production token here.
NEXT_PUBLIC_API_BASE=http://localhost:4000
# NEXT_PUBLIC_API_TOKEN was removed in Phase 3c — UI now uses session cookies via
# /api/auth/login. Kept here only for the verification window while older UI
# builds still read it; remove from .env once you've logged in once.
NEXT_PUBLIC_API_TOKEN=

# ============ Auth — Phase 3c ============
ADMIN_EMAIL=admin@local
ADMIN_PASSWORD=change-me-on-first-login
# When 'true', /api/auth/register is open. Default: false (admin creates users).
SIGNUPS_ENABLED=false

# ============ AI Providers ============
# Required for ai_agent workers. Each provider is independent — leave blank
# to disable that provider (multi-provider mode reports per-provider errors;
# single-call mode fails the job).
# Defaults: claude=claude-sonnet-4-5, gpt=gpt-4o, perplexity=sonar-pro
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
PERPLEXITY_API_KEY=

# ============ Discord ============
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=

# ============ Telegram ============
TELEGRAM_BOT_TOKEN=

# ============ Trading / Sportsbook ============
ESPN_API_BASE=https://site.api.espn.com/apis/site/v2/sports
CROSSBAR_API_URL=http://localhost:3001
# the-odds-api.com — free tier 500 req/mo. Used by Sportsbook Line Scraper.
# Public DK/FD endpoints reject non-residential IPs; this aggregator returns
# the same per-book data without bot-management friction.
ODDS_API_KEY=

# Hard gate for the trading pool. Default 'false' → all 'live'-mode trading
# bots refuse to run with a clear error. Set to 'true' on the trading worker
# (and restart it + the API) to enable real exchange calls. The UI also shows
# a permanent red banner site-wide whenever this is true.
TRADING_LIVE_ENABLED=false

# ============ Cloud (Phase 2) ============
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# FLY_API_TOKEN=
# RAILWAY_TOKEN=
