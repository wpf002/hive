{
  "name": "@hive/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "build": "tsc",
    "start": "node --env-file=../../.env dist/index.js",
    "typecheck": "tsc --noEmit",
    "seed": "tsx --env-file=../../.env src/seed.ts",
    "encrypt-existing-secrets": "tsx --env-file=../../.env src/scripts/encrypt-existing-secrets.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^9.3.0",
    "@fastify/cors": "^9.0.0",
    "@hive/crypto": "workspace:*",
    "@hive/db": "workspace:*",
    "@hive/shared": "workspace:*",
    "bcryptjs": "^2.4.3",
    "cron-parser": "^4.9.0",
    "fastify": "^4.28.0",
    "fastify-sse-v2": "^4.1.0",
    "ioredis": "^5.4.0",
    "pino": "^9.3.0",
    "pino-pretty": "^11.2.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
