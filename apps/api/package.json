{
  "name": "@hive/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=../../.env src/index.ts",
    "start:fly": "tsx src/index.ts",
    "build": "tsc",
    "start": "node --env-file-if-exists=../../.env dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test --test-force-exit \"src/**/*.test.ts\"",
    "test:integration": "node --env-file-if-exists=../../.env --import tsx --test --test-force-exit \"src/**/*.itest.ts\"",
    "seed": "tsx --env-file-if-exists=../../.env src/seed.ts",
    "seed:demo": "tsx --env-file-if-exists=../../.env src/seed-demo.ts",
    "encrypt-existing-secrets": "tsx --env-file-if-exists=../../.env src/scripts/encrypt-existing-secrets.ts",
    "upgrade-envelope-v1-to-v2": "tsx --env-file-if-exists=../../.env src/scripts/upgrade-envelope-v1-to-v2.ts",
    "kms:rotate": "tsx --env-file-if-exists=../../.env src/scripts/kms-rotate.ts",
    "migrate-artifacts-to-s3": "tsx --env-file-if-exists=../../.env src/scripts/migrate-artifacts-to-s3.ts",
    "smoke:sse": "tsx --env-file-if-exists=../../.env src/scripts/smoke-sse.ts",
    "smoke:phase5a": "tsx --env-file-if-exists=../../.env src/scripts/smoke-phase5a.ts",
    "smoke:kms-rotation": "tsx --env-file-if-exists=../../.env src/scripts/smoke-kms-rotation.ts",
    "smoke:upgrade-and-migrate": "tsx --env-file-if-exists=../../.env src/scripts/smoke-upgrade-and-migrate.ts",
    "smoke:migrate-to-s3": "tsx --env-file-if-exists=../../.env src/scripts/smoke-migrate-to-s3.ts",
    "smoke:phase5b": "tsx --env-file-if-exists=../../.env src/scripts/smoke-phase5b.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^9.3.0",
    "@fastify/cors": "^9.0.0",
    "@hive/crypto": "workspace:*",
    "@hive/db": "workspace:*",
    "@hive/email": "workspace:*",
    "@hive/kms": "workspace:*",
    "@hive/shared": "workspace:*",
    "@hive/storage": "workspace:*",
    "bcryptjs": "^2.4.3",
    "cron-parser": "^4.9.0",
    "fastify": "^4.28.0",
    "fastify-sse-v2": "^4.1.0",
    "@hive/worker-base-ts": "workspace:*",
    "ioredis": "^5.4.0",
    "pino": "^9.3.0",
    "pino-pretty": "^11.2.0",
    "sodium-native": "^4.3.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
