{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "deploy/fly/Dockerfile.ts-app",
    "dockerfileBuildArgs": { "SERVICE": "apps/session-sweeper" }
  },
  "deploy": {
    "startCommand": "pnpm --filter @hive/session-sweeper start",
    "healthcheckPath": "/healthz",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE"
  }
}
