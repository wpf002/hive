{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "deploy/fly/Dockerfile.ts-app",
    "dockerfileBuildArgs": { "SERVICE": "apps/ui" }
  },
  "deploy": {
    "startCommand": "pnpm --filter @hive/ui start",
    "healthcheckPath": "/",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE"
  }
}
