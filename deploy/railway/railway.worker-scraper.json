  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "deploy/fly/Dockerfile.python-worker",
    "dockerfileBuildArgs": { "WORKER": "scraper" }
  },
  "deploy": {
    "startCommand": "hive-scraper",
    "restartPolicyType": "ON_FAILURE"
  }
}
