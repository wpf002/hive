# Phase 4b — artifact storage (local filesystem; honors HIVE_ARTIFACT_DIR
# but defaults to a cwd-relative ./data/artifacts, which lands inside whichever
# service started — most often apps/api/data/artifacts. Glob catches both).
**/data/artifacts/
data/artifacts/

# Phase 6 production secrets (never commit)
deploy/fly/.secrets.env
deploy/fly/*.secrets.env
scripts/.localworker.env
