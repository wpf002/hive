{
  "folders": [
    { "name": "🐝 Hive (root)", "path": "." },
    { "name": "📡 api", "path": "apps/api" },
    { "name": "🖥️  ui", "path": "apps/ui" },
    { "name": "🚦 dispatcher", "path": "apps/dispatcher" },
    { "name": "📦 packages/db", "path": "packages/db" },
    { "name": "📦 packages/shared", "path": "packages/shared" },
    { "name": "🌐 worker: browser", "path": "workers/browser" },
    { "name": "🕷️  worker: scraper", "path": "workers/scraper" },
    { "name": "🤖 worker: ai_agent", "path": "workers/ai_agent" },
    { "name": "💱 worker: trading", "path": "workers/trading" },
    { "name": "📊 worker: monitor", "path": "workers/monitor" },
    { "name": "💬 worker: discord", "path": "workers/discord" },
    { "name": "✈️  worker: telegram", "path": "workers/telegram" },
    { "name": "🔌 worker: mcp_host", "path": "workers/mcp_host" },
    { "name": "🛠️  worker: rpa_desktop", "path": "workers/rpa_desktop" },
    { "name": "⚙️  worker: ci_agent", "path": "workers/ci_agent" },
    { "name": "📋 worker: task_runner", "path": "workers/task_runner" },
    { "name": "🐍 worker: base (py lib)", "path": "workers/base" }
  ],
  "settings": {
    "editor.formatOnSave": true,
    "editor.tabSize": 2,
    "editor.rulers": [100],
    "files.exclude": {
      "**/.git": true,
      "**/node_modules": true,
      "**/__pycache__": true,
      "**/.next": true,
      "**/dist": true,
      "**/.venv": true,
      "**/*.tsbuildinfo": true
    },
    "search.exclude": {
      "**/node_modules": true,
      "**/.venv": true,
      "**/.next": true,
      "**/dist": true,
      "**/pnpm-lock.yaml": true
    },
    "typescript.tsdk": "node_modules/typescript/lib",
    "typescript.enablePromptUseWorkspaceTsdk": true,
    "[python]": {
      "editor.tabSize": 4,
      "editor.defaultFormatter": "ms-python.black-formatter"
    },
    "[typescript]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
    "[typescriptreact]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
    "[json]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
    "[prisma]": { "editor.defaultFormatter": "Prisma.prisma" },
    "tailwindCSS.experimental.classRegex": [
      ["cva\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
      ["cn\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"]
    ],
    "python.analysis.typeCheckingMode": "basic",
    "python.terminal.activateEnvironment": true,
    "files.associations": { "*.css": "tailwindcss" },
    "workbench.colorTheme": "Default Dark Modern",
    "workbench.colorCustomizations": {
      "activityBar.background": "#0A0A0A",
      "activityBar.foreground": "#FFC107",
      "activityBarBadge.background": "#FF6B1A",
      "statusBar.background": "#0A0A0A",
      "statusBar.foreground": "#FFC107",
      "titleBar.activeBackground": "#0A0A0A",
      "titleBar.activeForeground": "#FFC107"
    }
  },
  "extensions": {
    "recommendations": [
      "anthropic.claude-code",
      "esbenp.prettier-vscode",
      "dbaeumer.vscode-eslint",
      "bradlc.vscode-tailwindcss",
      "prisma.prisma",
      "ms-python.python",
      "ms-python.black-formatter",
      "ms-python.vscode-pylance",
      "ms-azuretools.vscode-docker",
      "redhat.vscode-yaml",
      "yzhang.markdown-all-in-one",
      "usernamehw.errorlens",
      "christian-kohler.path-intellisense"
    ]
  }
}
